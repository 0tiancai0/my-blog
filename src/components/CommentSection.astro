---
// 自建评论组件
interface Props { slug: string }
const { slug } = Astro.props;
const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3456';
---

<div class="mt-16 pt-8 border-t border-[var(--c-border)]" id="comments" data-slug={slug}>
  <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
    <svg class="w-5 h-5 text-[var(--c-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    评论 <span id="comment-count" class="text-sm font-normal text-[var(--c-text-muted)]"></span>
  </h3>

  <!-- Login prompt (shown when not logged in) -->
  <div id="login-prompt" class="p-5 rounded-xl bg-[var(--c-bg-alt)] border border-[var(--c-border)] text-center">
    <p class="text-sm text-[var(--c-text-muted)] mb-3">登录后参与评论</p>
    <a href="/login" class="btn btn-primary text-sm !px-4 !py-1.5 no-underline">登录</a>
  </div>

  <!-- Comment form (shown when logged in) -->
  <form id="comment-form" class="space-y-3 mb-8 hidden">
    <input type="hidden" id="reply-parent-id" value="" />
    <div id="reply-indicator" class="text-xs text-[var(--c-text-muted)] bg-[var(--c-bg-alt)] px-3 py-1.5 rounded-lg hidden">
      回复 <span id="reply-target-name"></span>
      <button type="button" id="cancel-reply" class="ml-2 text-[var(--c-primary)] cursor-pointer border-none bg-transparent font-medium">取消</button>
    </div>
    <textarea id="comment-content" rows="3" placeholder="写下你的评论..." maxlength="5000"
      class="w-full px-4 py-3 rounded-xl border-2 border-[var(--c-border)] bg-[var(--c-bg)] text-[var(--c-text)] placeholder:text-[var(--c-text-soft)] outline-none transition-all focus:border-[var(--c-primary)] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.15)] resize-y"></textarea>
    <div class="flex items-center justify-between">
      <span class="text-xs text-[var(--c-text-soft)]" id="char-count">0 / 5000</span>
      <div class="flex items-center gap-2">
        <span id="comment-error" class="text-xs text-red-500 hidden"></span>
        <button type="submit" id="comment-submit" class="btn btn-primary text-sm !px-4 !py-1.5">发表评论</button>
      </div>
    </div>
  </form>

  <!-- Comments list -->
  <div id="comments-list" class="space-y-4"></div>
  <div id="comments-loading" class="text-center py-8 text-[var(--c-text-muted)] text-sm">加载中...</div>
  <div id="comments-empty" class="text-center py-8 text-[var(--c-text-soft)] text-sm hidden">暂无评论，来抢沙发 🛋️</div>
  <div id="comments-error" class="text-center py-8 text-red-400 text-sm hidden">加载失败，请刷新重试</div>
</div>

<script>
  const API = document.getElementById('api-config')?.dataset.base || 'http://localhost:3456';
  (function() {
    const _slug = document.getElementById('comments')?.dataset.slug
      || window.location.pathname.split('/posts/')[1]?.replace(/\/$/, '')
      || '';

    // API is read from #api-config element (injected by BaseLayout)

    function tok() { return localStorage.getItem('token') || ''; }
    function auth() { const t = tok(); return t ? { Authorization: 'Bearer ' + t } : {}; }
    function userId() {
      try { const t = tok(); if (!t) return null; return JSON.parse(atob(t.split('.')[1])).sub; }
      catch { return null; }
    }

    const loginPrompt = document.getElementById('login-prompt')!;
    const form = document.getElementById('comment-form')!;
    const textarea = document.getElementById('comment-content') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count')!;
    const submitBtn = document.getElementById('comment-submit') as HTMLButtonElement;
    const errorEl = document.getElementById('comment-error')!;
    const replyParentId = document.getElementById('reply-parent-id') as HTMLInputElement;
    const replyIndicator = document.getElementById('reply-indicator')!;
    const replyTargetName = document.getElementById('reply-target-name')!;
    const cancelReply = document.getElementById('cancel-reply')!;
    const listEl = document.getElementById('comments-list')!;
    const loadingEl = document.getElementById('comments-loading')!;
    const emptyEl = document.getElementById('comments-empty')!;
    const errEl = document.getElementById('comments-error')!;
    const countEl = document.getElementById('comment-count')!;

    // ── Auth state ──
    function updateUI() {
      if (tok()) { loginPrompt.classList.add('hidden'); form.classList.remove('hidden'); }
      else { loginPrompt.classList.remove('hidden'); form.classList.add('hidden'); }
    }
    updateUI();
    window.addEventListener('userchange', updateUI);

    // ── Char count ──
    textarea.addEventListener('input', () => { charCount.textContent = textarea.value.length + ' / 5000'; });

    // ── Reply ──
    cancelReply.addEventListener('click', () => {
      replyParentId.value = '';
      replyIndicator.classList.add('hidden');
      textarea.placeholder = '写下你的评论...';
    });

    (window as any)._replyTo = function(parentId: number, username: string) {
      replyParentId.value = String(parentId);
      replyIndicator.classList.remove('hidden');
      replyTargetName.textContent = '@' + username;
      textarea.placeholder = '回复 @' + username + '...';
      textarea.focus();
      form.scrollIntoView({ behavior: 'smooth' });
    };

    // ── Submit ──
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const content = textarea.value.trim();
      if (!content) return;

      submitBtn.textContent = '发表中...';
      submitBtn.disabled = true;
      errorEl.classList.add('hidden');

      try {
        const body: any = { slug: _slug, content };
        if (replyParentId.value) body.parentId = parseInt(replyParentId.value);

        const res = await fetch(API + '/api/comments', {
          method: 'POST',
          headers: { ...auth(), 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) { const d = await res.json(); throw new Error(d.error || '发表失败'); }

        textarea.value = '';
        charCount.textContent = '0 / 5000';
        replyParentId.value = '';
        replyIndicator.classList.add('hidden');
        textarea.placeholder = '写下你的评论...';
        await load();
      } catch (err: any) {
        errorEl.textContent = err.message;
        errorEl.classList.remove('hidden');
      }
      submitBtn.textContent = '发表评论';
      submitBtn.disabled = false;
    });

    // ── Delete ──
    (window as any)._deleteComment = async function(id: number) {
      if (!confirm('确定删除？')) return;
      await fetch(API + '/api/comments/' + id, { method: 'DELETE', headers: auth() });
      await load();
    };

    // ── Load ──
    async function load() {
      listEl.innerHTML = '';
      loadingEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      errEl.classList.add('hidden');

      try {
        const res = await fetch(API + '/api/comments?slug=' + encodeURIComponent(_slug), { headers: auth() });
        const data = await res.json();
        loadingEl.classList.add('hidden');

        if (!data.comments?.length) { emptyEl.classList.remove('hidden'); countEl.textContent = ''; return; }

        countEl.textContent = '(' + data.comments.length + ')';
        const uid = userId();

        // Group: root vs nested
        const roots = data.comments.filter((c: any) => !c.parentId);
        const children: Record<number, any[]> = {};
        data.comments.forEach((c: any) => {
          if (c.parentId) { if (!children[c.parentId]) children[c.parentId] = []; children[c.parentId].push(c); }
        });

        listEl.innerHTML = roots.map((c: any) => render(c, children, uid)).join('');
      } catch {
        loadingEl.classList.add('hidden');
        errEl.classList.remove('hidden');
      }
    }

    function render(c: any, children: Record<number, any[]>, uid: number | null, depth = 0): string {
      const d = new Date(c.createdAt + 'Z');
      const timeAgo = relTime(d);
      const isOwner = uid !== null && c.userId === uid;
      const replies = children[c.id] || [];
      const indent = depth > 0 ? ' ml-8 pl-4 border-l-2 border-[var(--c-border)]' : '';

      return `
        <div class="comment-item${indent}" id="c-${c.id}">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-[var(--c-primary-bg)] text-[var(--c-primary)] flex items-center justify-center text-sm font-bold shrink-0">${e(c.author).charAt(0).toUpperCase()}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-semibold text-[var(--c-text)]">${e(c.author)}</span>
                <time class="text-xs text-[var(--c-text-soft)]">${timeAgo}</time>
                ${isOwner ? '<button class="text-xs text-red-400 hover:text-red-500 cursor-pointer border-none bg-transparent" onclick="window._deleteComment(' + c.id + ')">删除</button>' : ''}
              </div>
              <p class="text-sm text-[var(--c-text)] leading-relaxed whitespace-pre-wrap">${e(c.content)}</p>
              ${tok() ? '<button class="text-xs text-[var(--c-text-muted)] hover:text-[var(--c-primary)] mt-1 cursor-pointer border-none bg-transparent" onclick="window._replyTo(' + c.id + ",'" + e(c.author) + '\')">回复</button>' : ''}
            </div>
          </div>
          ${replies.map((r: any) => render(r, children, uid, depth + 1)).join('')}
        </div>`;
    }

    function e(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    function relTime(d: Date): string {
      const diff = Math.floor((Date.now() - d.getTime()) / 1000);
      if (diff < 60) return '刚刚';
      if (diff < 3600) return Math.floor(diff / 60) + ' 分钟前';
      if (diff < 86400) return Math.floor(diff / 3600) + ' 小时前';
      if (diff < 2592000) return Math.floor(diff / 86400) + ' 天前';
      return d.toLocaleDateString('zh-CN');
    }

    load();
  })();
</script>
