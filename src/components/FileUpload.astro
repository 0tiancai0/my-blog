---
// 文件上传组件 — 拖拽/点击上传 + 真实进度条
---

<div class="file-upload-widget" id="file-upload-widget">
  <div
    id="drop-zone"
    class="relative p-8 rounded-xl border-2 border-dashed border-[var(--c-border)] bg-[var(--c-bg-alt)] transition-all duration-200 cursor-pointer hover:border-[var(--c-primary)] hover:bg-[var(--c-primary-bg)]/30"
  >
    <div class="flex flex-col items-center gap-3">
      <!-- Upload icon -->
      <svg class="w-10 h-10 text-[var(--c-text-soft)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
      </svg>
      <div class="text-center">
        <p class="text-sm font-medium text-[var(--c-text-muted)]">
          拖拽文件到此处，或 <span class="text-[var(--c-primary)] underline">点击选择</span>
        </p>
        <p class="text-xs text-[var(--c-text-soft)] mt-1">
          支持图片 (PNG/JPEG/GIF/WebP/SVG)、PDF、文本、压缩包，最大 10MB
        </p>
      </div>
    </div>

    <input
      id="file-input"
      type="file"
      class="absolute inset-0 opacity-0 cursor-pointer"
      accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,text/markdown,application/zip,application/gzip,application/x-tar,application/json,text/csv"
      multiple
    />
  </div>

  <!-- Files list (shown during and after upload) -->
  <div id="files-list" class="mt-4 space-y-2 hidden"></div>
</div>

<script>
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const filesList = document.getElementById('files-list')!;

  // 点击触发文件选择
  dropZone.addEventListener('click', () => fileInput.click());

  // 拖拽事件
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('!border-[var(--c-primary)]', '!bg-[var(--c-primary-bg)]/50');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('!border-[var(--c-primary)]', '!bg-[var(--c-primary-bg)]/50');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('!border-[var(--c-primary)]', '!bg-[var(--c-primary-bg)]/50');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) uploadFiles(files);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) uploadFiles(fileInput.files);
  });

  async function uploadFiles(fileList: FileList) {
    const files = Array.from(fileList);
    filesList.classList.remove('hidden');

    for (const file of files) {
      const itemEl = addFileItem(file.name, file.type);
      await uploadSingle(file, itemEl);
    }

    fileInput.value = '';
  }

  function uploadSingle(file: File, itemEl: HTMLElement): Promise<void> {
    return new Promise((resolve) => {
      const formData = new FormData();
      formData.append('file', file);

      const xhr = new XMLHttpRequest();

      // 真实上传进度
      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) {
          const pct = Math.round((e.loaded / e.total) * 100);
          updateItemProgress(itemEl, pct, `上传中 ${pct}%`);
        }
      });

      xhr.addEventListener('load', () => {
        try {
          const data = JSON.parse(xhr.responseText);
          if (xhr.status >= 200 && xhr.status < 300 && data.success) {
            updateItemSuccess(itemEl, data.url, file.type, data.deduplicated ? '(已存在，已去重)' : undefined);
          } else {
            updateItemError(itemEl, data.error || '上传失败');
          }
        } catch {
          updateItemError(itemEl, '服务器响应异常');
        }
        resolve();
      });

      xhr.addEventListener('error', () => {
        updateItemError(itemEl, '网络错误');
        resolve();
      });

      xhr.addEventListener('abort', () => {
        updateItemError(itemEl, '上传已取消');
        resolve();
      });

      xhr.open('POST', '/api/upload');
      xhr.send(formData);
    });
  }

  // ---- DOM helpers ----

  function addFileItem(name: string, type: string): HTMLElement {
    const item = document.createElement('div');
    item.className = 'flex items-center gap-3 p-3 rounded-lg bg-[var(--c-bg-alt)] border border-[var(--c-border)]';
    item.innerHTML = `
      <span class="shrink-0 text-lg">${type.startsWith('image/') ? '🖼️' : '📄'}</span>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium truncate">${escapeHtml(name)}</p>
        <div class="mt-1 flex items-center gap-2">
          <div class="flex-1 h-1.5 rounded-full bg-[var(--c-border)] overflow-hidden">
            <div class="progress-fill h-full bg-[var(--c-primary)] rounded-full transition-all duration-150" style="width: 0%"></div>
          </div>
          <span class="progress-text text-xs text-[var(--c-text-soft)] shrink-0">等待中</span>
        </div>
      </div>
    `;
    filesList.appendChild(item);
    return item;
  }

  function updateItemProgress(item: HTMLElement, pct: number, text: string) {
    const fill = item.querySelector('.progress-fill') as HTMLElement;
    const txt = item.querySelector('.progress-text') as HTMLElement;
    if (fill) fill.style.width = pct + '%';
    if (txt) txt.textContent = text;
  }

  function updateItemSuccess(item: HTMLElement, url: string, type: string, note?: string) {
    const isImage = type.startsWith('image/');
    const noteHtml = note ? `<span class="text-xs text-[var(--c-text-soft)] ml-1">${escapeHtml(note)}</span>` : '';

    item.innerHTML = `
      <span class="shrink-0 text-lg">${isImage ? '🖼️' : '📄'}</span>
      <div class="flex-1 min-w-0">
        <a href="${url}" target="_blank" rel="noopener" class="text-sm font-medium text-[var(--c-primary)] hover:underline truncate block">${url.split('/').pop()}</a>
        ${noteHtml}
        ${isImage ? `<img src="${url}" alt="" class="mt-2 rounded-lg max-h-32 object-cover" loading="lazy" />` : ''}
      </div>
      <div class="flex items-center gap-1 shrink-0">
        <button class="btn-copy btn-ghost text-xs !px-2 !py-1" data-url="${url}" title="复制链接">📋</button>
        <span class="text-xs text-green-500">✅</span>
      </div>
    `;

    // 绑定复制按钮
    const btn = item.querySelector('.btn-copy') as HTMLButtonElement;
    if (btn) {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(btn.dataset.url || url).then(() => {
          btn.textContent = '✅';
          setTimeout(() => { btn.textContent = '📋'; }, 1500);
        });
      });
    }
  }

  function updateItemError(item: HTMLElement, error: string) {
    const fill = item.querySelector('.progress-fill') as HTMLElement;
    if (fill) fill.classList.add('!bg-red-500');
    updateItemProgress(item, 100, error);
  }

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
</script>
