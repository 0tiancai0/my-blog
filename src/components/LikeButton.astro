---
// 点赞按钮 — 同源 Vercel Serverless API
interface Props { slug: string }
const { slug } = Astro.props;
---

<div class="like-area flex items-center gap-3 my-10 pt-6 border-t border-[var(--c-border)]" data-slug={slug}>
  <button
    id="like-btn"
    class="group flex items-center gap-2 px-5 py-2.5 rounded-full border border-[var(--c-border)] bg-[var(--c-surface)] hover:border-pink-300 hover:bg-pink-50 dark:hover:bg-pink-950/20 transition-all duration-200 cursor-pointer disabled:opacity-70 disabled:cursor-default"
    aria-label="点赞"
  >
    <svg
      id="like-icon"
      class="w-5 h-5 text-[var(--c-text-soft)] group-hover:text-pink-500 transition-colors"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
    </svg>
    <span id="like-count" class="text-sm font-semibold text-[var(--c-text-muted)] group-hover:text-pink-500 transition-colors">--</span>
  </button>
  <span id="like-msg" class="text-xs text-[var(--c-text-soft)]"></span>
</div>

<script>
  const container = document.querySelector('.like-area') as HTMLElement;
  if (!container) throw new Error('No .like-area');
  const slug = container.dataset.slug!;
  const KEY = 'liked:' + slug;

  const btn = document.getElementById('like-btn') as HTMLButtonElement;
  const countEl = document.getElementById('like-count')!;
  const iconEl = document.getElementById('like-icon')!;
  const msgEl = document.getElementById('like-msg')!;

  function showMsg(text: string, isError?: boolean) {
    msgEl.textContent = text;
    msgEl.className = 'text-xs ' + (isError ? 'text-red-400' : 'text-[var(--c-text-soft)]');
    if (text) setTimeout(() => { msgEl.textContent = ''; }, 3000);
  }

  function markLiked() {
    btn.classList.add('!border-pink-300', '!bg-pink-50');
    btn.classList.add('dark:!bg-pink-950/20');
    iconEl.classList.add('text-pink-500');
    iconEl.setAttribute('fill', 'currentColor');
    countEl.classList.add('text-pink-500');
    btn.disabled = true;
  }

  // 加载点赞数
  (async function() {
    try {
      const res = await fetch('/api/likes?slug=' + encodeURIComponent(slug));
      if (res.ok) {
        const data = await res.json();
        countEl.textContent = String(data.likes);
      } else {
        countEl.textContent = '0';
      }
    } catch(e) {
      countEl.textContent = '0';
      console.log('[Like] fetch count failed:', e);
    }

    if (localStorage.getItem(KEY) === 'true') {
      markLiked();
      showMsg('已点赞 ✓');
    }
  })();

  // 点击点赞
  btn.addEventListener('click', async function() {
    if (localStorage.getItem(KEY) === 'true') {
      showMsg('你已经点过赞了 ❤️');
      return;
    }

    btn.disabled = true;
    showMsg('...');

    try {
      const res = await fetch('/api/likes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug }),
      });
      const data = await res.json();

      if (res.ok) {
        countEl.textContent = String(data.likes);
        localStorage.setItem(KEY, 'true');
        markLiked();
        showMsg('谢谢点赞！❤️');
      } else if (res.status === 429) {
        countEl.textContent = String(data.likes ?? 0);
        localStorage.setItem(KEY, 'true');
        markLiked();
        showMsg('你已经点过赞了');
      } else {
        // 服务器错误（如 500），用乐观更新
        console.warn('[Like] server error:', res.status, data);
        const prev = parseInt(countEl.textContent || '0') || 0;
        countEl.textContent = String(prev + 1);
        localStorage.setItem(KEY, 'true');
        markLiked();
        showMsg('点赞成功！', false);
      }
    } catch(e) {
      console.warn('[Like] network error:', e);
      const prev = parseInt(countEl.textContent || '0') || 0;
      countEl.textContent = String(prev + 1);
      localStorage.setItem(KEY, 'true');
      markLiked();
      showMsg('已点赞（离线同步）');
    }

    btn.disabled = true;
  });
</script>
