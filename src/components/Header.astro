---
const navItems = [
  { label: '首页', href: '/' },
  { label: '博客', href: '/#posts' },
  { label: '关于', href: '/about' },
];
---

<header class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-md border-b border-[var(--color-border)]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold text-[var(--color-primary)] hover:text-[var(--color-primary-hover)] transition-colors no-underline">
      🏠 我的博客
    </a>

    <!-- Nav -->
    <nav class="hidden sm:flex items-center gap-6">
      {navItems.map(item => (
        <a
          href={item.href}
          class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors no-underline text-sm font-medium"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right: Theme + Admin -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle -->
      <button
        onclick="window.toggleTheme?.()"
        class="p-2 rounded-lg text-[var(--color-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-border)] transition-colors cursor-pointer"
        aria-label="切换主题"
        title="切换亮/暗主题"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="hidden dark:block w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="block dark:hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- Admin link -->
      <a
        href="/admin"
        class="text-sm px-3 py-1.5 rounded-lg bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-hover)] transition-colors no-underline font-medium"
      >
        管理
      </a>

      <!-- Mobile menu trigger -->
      <button
        class="sm:hidden p-2 rounded-lg text-[var(--color-muted)] hover:text-[var(--color-text)] cursor-pointer"
        aria-label="菜单"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
