---
const nav = [
  { label: '首页', href: '/' },
  { label: '博客', href: '/#posts' },
  { label: '关于', href: '/about' },
];
---

<header class="sticky top-0 z-50 h-16 border-b border-[var(--c-border)] bg-[var(--c-bg)]/80 backdrop-blur-xl supports-[backdrop-filter]:bg-[var(--c-bg)]/60">
  <div class="max-w-[var(--content-width)] mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-[var(--c-text)] no-underline hover:text-[var(--c-primary)] transition-colors">
      <span class="w-8 h-8 rounded-lg bg-[var(--c-primary)] text-white flex items-center justify-center text-sm font-extrabold">B</span>
      TianCai的博客
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden sm:flex items-center gap-1">
      {nav.map(item => (
        <a
          href={item.href}
          class="px-3 py-2 rounded-lg text-sm font-medium text-[var(--c-text-muted)] hover:text-[var(--c-text)] hover:bg-[var(--c-bg-alt)] transition-all no-underline"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Search -->
      <a
        href="/search"
        class="btn-ghost rounded-lg p-2"
        aria-label="搜索文章"
        title="搜索"
      >
        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </a>

      <button
        onclick="window.toggleTheme?.()"
        class="btn-ghost rounded-lg p-2 cursor-pointer"
        aria-label="切换主题"
        title="切换亮/暗主题"
      >
        <svg class="hidden dark:block w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg class="block dark:hidden w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>

      <!-- User menu (client-side rendered) -->
      <div id="user-menu" class="flex items-center">
        <a href="/login" id="login-link" class="btn btn-outline text-sm !px-3 !py-1.5 no-underline">
          登录
        </a>
        <div id="user-dropdown" class="hidden relative">
          <button id="user-btn" class="btn-ghost rounded-lg px-3 py-1.5 text-sm font-medium flex items-center gap-1.5 cursor-pointer">
            <span id="user-name-display"></span>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="dropdown-menu" class="hidden absolute right-0 top-full mt-1 w-40 bg-[var(--c-surface)] border border-[var(--c-border)] rounded-xl shadow-lg py-1 z-50">
            <a href="/favorites" class="block px-4 py-2 text-sm text-[var(--c-text)] hover:bg-[var(--c-bg-alt)] no-underline">
              ❤️ 我的收藏
            </a>
            <hr class="my-1 border-[var(--c-border)]" />
            <button id="logout-btn" class="w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-[var(--c-bg-alt)] cursor-pointer border-none bg-transparent">
              退出登录
            </button>
          </div>
        </div>
      </div>

      <a href="/admin" class="btn btn-primary text-sm !px-3 !py-1.5 no-underline">
        管理
      </a>
    </div>
  </div>
</header>

<script>
  // ── User state management ──
  function getUser() {
    try {
      const token = localStorage.getItem('token');
      if (!token) return null;
      const payload = JSON.parse(atob(token.split('.')[1]));
      return { id: payload.sub, username: payload.username };
    } catch {
      return null;
    }
  }

  function updateUI() {
    const user = getUser();
    const loginLink = document.getElementById('login-link');
    const dropdown = document.getElementById('user-dropdown');
    const nameDisplay = document.getElementById('user-name-display');

    if (user) {
      loginLink?.classList.add('hidden');
      dropdown?.classList.remove('hidden');
      if (nameDisplay) nameDisplay.textContent = user.username;
    } else {
      loginLink?.classList.remove('hidden');
      dropdown?.classList.add('hidden');
    }
  }

  // Toggle dropdown
  document.getElementById('user-btn')?.addEventListener('click', () => {
    document.getElementById('dropdown-menu')?.classList.toggle('hidden');
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    const menu = document.getElementById('user-dropdown');
    if (menu && !menu.contains(e.target as Node)) {
      document.getElementById('dropdown-menu')?.classList.add('hidden');
    }
  });

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('token');
    window.dispatchEvent(new CustomEvent('userchange'));
    updateUI();
    window.location.reload();
  });

  // Listen for user changes
  window.addEventListener('userchange', updateUI);

  // Initial render
  updateUI();
</script>
