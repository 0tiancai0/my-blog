---
// Giscus 评论组件 — 基于 GitHub Discussions，自动关联 GitHub 账号
interface Props { slug: string }
const { slug } = Astro.props;

// 从服务端环境变量读取 Giscus 配置
const repoId = import.meta.env.GISCUS_REPO_ID || '';
const category = import.meta.env.GISCUS_CATEGORY || 'Announcements';
const categoryId = import.meta.env.GISCUS_CATEGORY_ID || '';
const configured = !!(repoId && categoryId);
---

<div class="mt-16 pt-8 border-t border-[var(--c-border)]" id="comments">
  <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
    <svg class="w-5 h-5 text-[var(--c-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    评论
  </h3>

  {configured ? (
    <div class="giscus"></div>
  ) : (
    <div class="p-8 rounded-xl bg-[var(--c-bg-alt)] border border-[var(--c-border)] text-center">
      <p class="text-[var(--c-text-muted)] text-sm mb-4">
        ⚙️ 评论系统尚未配置
      </p>
      <div class="text-xs text-[var(--c-text-soft)] text-left max-w-md mx-auto space-y-1.5">
        <p class="font-semibold text-[var(--c-text-muted)] mb-2">Giscus 配置步骤：</p>
        <p>1. 仓库 Settings → Features → 开启 <strong>Discussions</strong></p>
        <p>2. 安装 <a href="https://github.com/apps/giscus" class="text-[var(--c-primary)] underline" target="_blank">Giscus App</a></p>
        <p>3. 访问 <a href="https://giscus.app/zh-CN" class="text-[var(--c-primary)] underline" target="_blank">giscus.app</a> 填入仓库 0tiancai0/my-blog，获取 ID</p>
        <p>4. 将 <code>GISCUS_REPO_ID</code> 和 <code>GISCUS_CATEGORY_ID</code> 添加到 Vercel 环境变量</p>
      </div>
    </div>
  )}
</div>

<!-- 通过 data 属性将服务端配置传给客户端 JS -->
<div
  id="giscus-config"
  data-repo-id={repoId}
  data-category-id={categoryId}
  data-category={category}
  hidden
></div>

<script>
  const config = document.getElementById('giscus-config');
  const repoId = config?.dataset.repoId;
  const categoryId = config?.dataset.categoryId;
  const category = config?.dataset.category || 'Announcements';

  if (repoId && categoryId) {
    const container = document.querySelector('#comments .giscus');
    if (container) {
      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', '0tiancai0/my-blog');
      script.setAttribute('data-repo-id', repoId);
      script.setAttribute('data-category', category);
      script.setAttribute('data-category-id', categoryId);
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'top');
      script.setAttribute('data-theme', 'preferred_color_scheme');
      script.setAttribute('data-lang', 'zh-CN');
      script.setAttribute('data-loading', 'lazy');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;
      container.appendChild(script);
    }
  }
</script>
