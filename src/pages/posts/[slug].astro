---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommentSection from '../../components/CommentSection.astro';
import LikeButton from '../../components/LikeButton.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';

// 预渲染所有文章页面
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
if (!slug) return new Response('Not Found', { status: 404 });

const post = await getEntry('posts', slug);
if (!post) return new Response('Not Found', { status: 404 });

const { title, description, pubDate, tags, heroImage } = post.data;
const { Content } = await post.render();

const dateStr = pubDate
  ? new Date(pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const readingTime = Math.max(1, Math.ceil((post.body?.length || 0) / 800));
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article class="max-w-[var(--prose-width)] mx-auto py-12 animate-in animate-in-1">
    <!-- Header -->
    <header class="mb-10">
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4 leading-tight tracking-tight">{title}</h1>

      {description && <p class="text-lg text-[var(--c-text-muted)] mb-4">{description}</p>}

      <div class="flex items-center gap-4 text-sm text-[var(--c-text-soft)]">
        {dateStr && (
          <time datetime={pubDate?.toISOString()} class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            {dateStr}
          </time>
        )}
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {readingTime} 分钟阅读
        </span>
      </div>
    </header>

    <!-- Cover -->
    {heroImage && <img src={heroImage} alt={title} class="w-full rounded-2xl mb-10 object-cover max-h-96 shadow-lg" loading="lazy" />}

    <!-- Content -->
    <div class="prose"><Content /></div>

    <!-- Like + Favorite -->
    <div class="flex items-center gap-6 my-10 pt-6 border-t border-[var(--c-border)]">
      <LikeButton slug={post.slug} />
      <FavoriteButton slug={post.slug} title={title} />
    </div>

    <!-- Comments -->
    <CommentSection slug={post.slug} />
  </article>
</BaseLayout>
