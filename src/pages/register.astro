---
import BaseLayout from '../layouts/BaseLayout.astro';
const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3456';
---

<BaseLayout title="注册" description="注册博客账号" noIndex>
  <div class="max-w-md mx-auto py-20 px-4">
    <div class="text-center mb-10 animate-in animate-in-1">
      <h1 class="text-3xl font-extrabold text-[var(--c-text)] mb-2">注册</h1>
      <p class="text-[var(--c-text-muted)]">创建账号以使用评论、点赞和收藏功能</p>
    </div>

    <div class="card p-8 animate-in animate-in-2">
      <form id="register-form" class="space-y-5">
        <!-- Username -->
        <div>
          <label for="username" class="block text-sm font-medium text-[var(--c-text)] mb-1.5">用户名</label>
          <input
            type="text" id="username" name="username" autocomplete="username" required
            minlength="2" maxlength="50"
            class="w-full px-4 py-2.5 rounded-xl border-2 border-[var(--c-border)] bg-[var(--c-bg)] text-[var(--c-text)] outline-none transition-all focus:border-[var(--c-primary)] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.15)]"
            placeholder="2-50个字符，支持中文"
          />
        </div>

        <!-- Password -->
        <div>
          <label for="password" class="block text-sm font-medium text-[var(--c-text)] mb-1.5">密码</label>
          <input
            type="password" id="password" name="password" autocomplete="new-password" required
            minlength="6"
            class="w-full px-4 py-2.5 rounded-xl border-2 border-[var(--c-border)] bg-[var(--c-bg)] text-[var(--c-text)] outline-none transition-all focus:border-[var(--c-primary)] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.15)]"
            placeholder="至少6个字符"
          />
        </div>

        <!-- Confirm Password -->
        <div>
          <label for="confirm-password" class="block text-sm font-medium text-[var(--c-text)] mb-1.5">确认密码</label>
          <input
            type="password" id="confirm-password" name="confirm-password" autocomplete="new-password" required
            class="w-full px-4 py-2.5 rounded-xl border-2 border-[var(--c-border)] bg-[var(--c-bg)] text-[var(--c-text)] outline-none transition-all focus:border-[var(--c-primary)] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.15)]"
            placeholder="再次输入密码"
          />
        </div>

        <!-- Error message -->
        <div id="error-msg" class="text-sm text-red-500 hidden"></div>

        <!-- Submit -->
        <button type="submit" id="submit-btn" class="btn btn-primary w-full justify-center py-3 text-base">
          注册
        </button>
      </form>

      <!-- Login link -->
      <p class="text-center text-sm text-[var(--c-text-muted)] mt-6">
        已有账号？<a href="/login" class="text-[var(--c-primary)] font-medium underline">立即登录</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const API = document.getElementById('api-config')?.dataset.base || 'http://localhost:3456';
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorEl = document.getElementById('error-msg')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = (document.getElementById('username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

    // Client-side validation
    if (!username || !password) {
      errorEl.textContent = '请填写所有字段';
      errorEl.classList.remove('hidden');
      return;
    }

    if (username.length < 2 || username.length > 50) {
      errorEl.textContent = '用户名需要 2-50 个字符';
      errorEl.classList.remove('hidden');
      return;
    }

    if (!/^[a-zA-Z0-9_一-鿿]+$/.test(username)) {
      errorEl.textContent = '用户名只能包含字母、数字、下划线和中文';
      errorEl.classList.remove('hidden');
      return;
    }

    if (password.length < 6) {
      errorEl.textContent = '密码至少需要 6 个字符';
      errorEl.classList.remove('hidden');
      return;
    }

    if (password !== confirmPassword) {
      errorEl.textContent = '两次密码不一致';
      errorEl.classList.remove('hidden');
      return;
    }

    submitBtn.textContent = '注册中...';
    submitBtn.disabled = true;
    errorEl.classList.add('hidden');

    try {
      const res = await fetch(`${API}/api/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorEl.textContent = data.error || '注册失败';
        errorEl.classList.remove('hidden');
        submitBtn.textContent = '注册';
        submitBtn.disabled = false;
        return;
      }

      // Store token and redirect
      localStorage.setItem('token', data.token);
      window.dispatchEvent(new CustomEvent('userchange'));
      window.location.href = '/';
    } catch (err) {
      errorEl.textContent = '网络错误，请稍后重试';
      errorEl.classList.remove('hidden');
      submitBtn.textContent = '注册';
      submitBtn.disabled = false;
    }
  });
</script>
