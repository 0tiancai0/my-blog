# ========================================
# TinaCMS (Tina Cloud) - https://app.tina.io
# ========================================
TINA_CLIENT_ID=
TINA_TOKEN=
TINA_SEARCH_TOKEN=

# ========================================
# JWT Secret (自建用户认证系统)
# 生产环境请使用随机字符串
# ========================================
JWT_SECRET=change-me-in-production

# ========================================
# Admin Token (管理后台/删除评论)
# ========================================
ADMIN_TOKEN=admin-secret-change-me

# ========================================
# Fastify API 地址
# 本地开发: http://localhost:3456
# Docker/生产: 留空（通过 Nginx 代理）
# ========================================
PUBLIC_API_URL=http://localhost:3456

# ========================================
# Upstash Redis (点赞 - 兼容保留，推荐使用自建 Fastify API)
# ========================================
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ========================================
# Site Config
# ========================================
SITE_URL=http://localhost:4321
