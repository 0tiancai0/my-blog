# ========================================
# TinaCMS (Tina Cloud) - https://app.tina.io
# ========================================
TINA_CLIENT_ID=
TINA_TOKEN=
TINA_SEARCH_TOKEN=

# ========================================
# API 服务器（博客前端用）
# ========================================
# 本地开发: http://localhost:3456
# 生产环境: http://<阿里云公网IP>:3456
PUBLIC_API_URL=http://localhost:3456

# ========================================
# 阿里云服务器环境变量
# ========================================
# API 服务端口
PORT=3456
# 管理员 token（用于删除评论等操作）
ADMIN_TOKEN=your-secret-token-here
# 允许跨域的前端地址（生产环境改为 Vercel 域名）
FRONTEND_URL=http://localhost:4321

# ========================================
# Site Config
# ========================================
SITE_URL=http://localhost:4321
