# ========================================
# TinaCMS (Tina Cloud) - https://app.tina.io
# ========================================
TINA_CLIENT_ID=
TINA_TOKEN=
TINA_SEARCH_TOKEN=

# ========================================
# Upstash Redis (点赞系统) - https://console.upstash.com
# 创建免费 Redis 数据库后获取 REST URL 和 Token
# ========================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========================================
# Vercel Blob (文件上传存储)
# 生产环境自动注入，本地开发需手动创建 Token:
#   npx vercel env pull .env
# ========================================
# BLOB_READ_WRITE_TOKEN=

# ========================================
# Giscus (GitHub Discussions 评论) - https://giscus.app/zh-CN
# 配置步骤:
#   1. 仓库 Settings → Features → 开启 Discussions
#   2. 安装 Giscus App: https://github.com/apps/giscus
#   3. 访问 https://giscus.app/zh-CN 填入 0tiancai0/my-blog
#   4. 将生成的 repo-id / category-id 填入下方
# ========================================
GISCUS_REPO_ID=
GISCUS_CATEGORY=Announcements
GISCUS_CATEGORY_ID=

# ========================================
# Site Config
# ========================================
SITE_URL=http://localhost:4321
